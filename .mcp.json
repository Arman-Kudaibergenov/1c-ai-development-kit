{
  "mcpServers": {
    "rlm-toolkit": {
      "type": "http",
      "url": "http://YOUR_RLM_SERVER:8200/mcp"
    },
    "context-mode": {
      "type": "stdio",
      "command": "cmd",
      "args": ["/c", "npx", "-y", "context-mode"]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--timeout",
        "500"
      ]
    }
  }
}